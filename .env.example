# Pulse Configuration
# Copy this file to .env and fill in your values

# Email Provider: resend, sendgrid, or mock (default)
EMAIL_PROVIDER=mock

# Email API Key (required for resend/sendgrid)
# Get your API key from:
# - Resend: https://resend.com/api-keys
# - SendGrid: https://app.sendgrid.com/settings/api_keys
EMAIL_API_KEY=

# Email sender configuration
EMAIL_FROM=noreply@pulse.app
EMAIL_FROM_NAME=Pulse API Client

# Note: Mock mode will print email previews to console
# Set EMAIL_PROVIDER=resend and provide EMAIL_API_KEY to send real emails
